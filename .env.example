# Copy to .env.local

# PostgreSQL connection string
DATABASE_URL="postgresql://pizzalogs:pizzalogs@localhost:5432/pizzalogs?schema=public"

# Python parser service URL (Docker service name in compose, localhost in dev)
PARSER_SERVICE_URL="http://localhost:8000"

# Required in production. Local dev may omit it.
ADMIN_SECRET="replace-with-a-long-random-secret"
# Optional for local HTTP-only production-mode compose. Do not set false in Railway.
# ADMIN_COOKIE_SECURE="false"

# Upload storage directory (absolute path)
UPLOAD_DIR="./uploads"

# Max file size in bytes (default 1 GB)
MAX_FILE_SIZE_BYTES=1073741824

# Optional: default realm when not specified
DEFAULT_REALM_NAME="Lordaeron"
DEFAULT_REALM_HOST="warmane"
