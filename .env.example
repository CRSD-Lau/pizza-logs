# Copy to .env.local

# PostgreSQL connection string
DATABASE_URL="postgresql://pizzalogs:pizzalogs@localhost:5432/pizzalogs?schema=public"

# Python parser service URL
PARSER_SERVICE_URL="http://localhost:8000"

# Required in production. Local dev may use a placeholder.
ADMIN_SECRET="replace-with-a-long-random-secret"

# Optional for local HTTP-only production-mode compose.
# Do not set false in Railway.
# ADMIN_COOKIE_SECURE="false"
