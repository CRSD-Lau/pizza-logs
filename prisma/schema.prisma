generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  REALM & GUILD
// ─────────────────────────────────────────────

model Realm {
  id        String   @id @default(cuid())
  name      String   // "Lordaeron", "Icecrown", "Retail"
  host      String   // "warmane", "blizzard", "kronos"
  expansion String   @default("wotlk") // wotlk | cata | mop | retail
  guilds    Guild[]
  uploads   Upload[]
  players   Player[]
  createdAt DateTime @default(now())

  @@unique([name, host])
  @@map("realms")
}

model Guild {
  id        String     @id @default(cuid())
  name      String
  realmId   String
  realm     Realm      @relation(fields: [realmId], references: [id])
  uploads   Upload[]
  createdAt DateTime   @default(now())

  @@unique([name, realmId])
  @@map("guilds")
}

// ─────────────────────────────────────────────
//  BOSS CONFIG  (seeded from constants)
// ─────────────────────────────────────────────

model Boss {
  id         String      @id @default(cuid())
  name       String
  slug       String      @unique // url-safe slug
  raid       String      // "Icecrown Citadel"
  raidSlug   String      // "icecrown-citadel"
  wowBossId  Int?        // numeric encounter ID from ENCOUNTER_START
  sortOrder  Int         @default(0)
  encounters Encounter[]

  @@map("bosses")
}

// ─────────────────────────────────────────────
//  UPLOAD / FILE
// ─────────────────────────────────────────────

model Upload {
  id             String       @id @default(cuid())
  filename       String
  fileHash       String       @unique // SHA-256 hex — prevents exact duplicate uploads
  fileSize       Int          // bytes
  status         UploadStatus @default(PENDING)
  guildId        String?
  guild          Guild?       @relation(fields: [guildId], references: [id])
  realmId        String?
  realm          Realm?       @relation(fields: [realmId], references: [id])
  encounters     Encounter[]
  uploaderName   String?      // character name of the person who uploaded
  errorMessage   String?
  parsedAt       DateTime?
  rawLineCount   Int?
  sessionDamage  Json?        // { "0": 407718447.0, "1": 200402269.0, … } full-log dmg per session
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("uploads")
}

enum UploadStatus {
  PENDING
  PARSING
  DONE
  FAILED
  DUPLICATE
}

// ─────────────────────────────────────────────
//  ENCOUNTER
// ─────────────────────────────────────────────

model Encounter {
  id              String        @id @default(cuid())
  uploadId        String
  upload          Upload        @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  bossId          String
  boss            Boss          @relation(fields: [bossId], references: [id])
  fingerprint     String        @unique // deterministic dedup hash
  outcome         Outcome       @default(UNKNOWN)
  difficulty      String        // "10N" | "10H" | "25N" | "25H"
  groupSize       Int           @default(10)
  sessionIndex    Int           @default(0)  // which raid session within the upload (0-based)
  durationSeconds Int
  durationMs      Int           @default(0)
  startedAt       DateTime
  endedAt         DateTime
  totalDamage     Float         @default(0)
  totalHealing    Float         @default(0)
  totalDamageTaken Float        @default(0)
  participants    Participant[]
  milestones      Milestone[]
  createdAt       DateTime      @default(now())

  @@index([bossId])
  @@index([startedAt])
  @@map("encounters")
}

enum Outcome {
  KILL
  WIPE
  UNKNOWN
}

// ─────────────────────────────────────────────
//  PLAYER
// ─────────────────────────────────────────────

model Player {
  id           String        @id @default(cuid())
  name         String
  class        String?       // normalized WoW class name
  realmId      String?
  realm        Realm?        @relation(fields: [realmId], references: [id])
  participants Participant[]
  milestones   Milestone[]
  createdAt    DateTime      @default(now())

  @@unique([name, realmId])
  @@map("players")
}

model ArmoryGearCache {
  id            String   @id @default(cuid())
  characterName String
  characterKey  String
  realm         String   @default("Lordaeron")
  sourceUrl     String
  gear          Json
  fetchedAt     DateTime
  lastAttemptAt DateTime @default(now())
  lastError     String?
  lastSuccessAt DateTime?
  sourceAgent   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([characterKey, realm])
  @@index([fetchedAt])
  @@map("armory_gear_cache")
}

model GuildRosterMember {
  id                      String   @id @default(cuid())
  characterName           String   @map("character_name")
  normalizedCharacterName String   @map("normalized_character_name")
  guildName               String   @map("guild_name")
  realm                   String   @default("Lordaeron")
  className               String?  @map("class_name")
  raceName                String?  @map("race_name")
  level                   Int?
  rankName                String?  @map("rank_name")
  rankOrder               Int?     @map("rank_order")
  professionsJson         Json?    @map("professions_json")
  gearScore               Int?     @map("gear_score")
  armoryUrl               String   @map("armory_url")
  gearSnapshotJson        Json?    @map("gear_snapshot_json")
  lastSyncedAt            DateTime @map("last_synced_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@unique([normalizedCharacterName, guildName, realm])
  @@index([guildName, realm])
  @@index([guildName, realm, rankOrder])
  @@index([lastSyncedAt])
  @@map("guild_roster_members")
}

// ─────────────────────────────────────────────
//  PARTICIPANT (player stats within one encounter)
// ─────────────────────────────────────────────

model Participant {
  id             String    @id @default(cuid())
  encounterId    String
  encounter      Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  playerId       String
  player         Player    @relation(fields: [playerId], references: [id])
  role           Role      @default(UNKNOWN)
  totalDamage    Float     @default(0)
  totalHealing   Float     @default(0)
  damageTaken    Float     @default(0)
  dps            Float     @default(0)
  hps            Float     @default(0)
  deaths         Int       @default(0)
  critPct        Float     @default(0) // 0-100
  spellBreakdown  Json?     // Record<spellName, { damage, healing, hits, crits, school }>
  targetBreakdown Json?    // Record<mobName,   { damage, hits, crits }>
  createdAt       DateTime @default(now())

  @@unique([encounterId, playerId])
  @@index([playerId])
  @@map("participants")
}

enum Role {
  DPS
  HEALER
  TANK
  UNKNOWN
}

// ─────────────────────────────────────────────
//  MILESTONE
// ─────────────────────────────────────────────

model Milestone {
  id            String        @id @default(cuid())
  type          MilestoneType
  rank          Int           // actual numeric rank (1, 2, 3 …)
  playerId      String
  player        Player        @relation(fields: [playerId], references: [id])
  encounterId   String
  encounter     Encounter     @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  bossId        String
  difficulty    String
  metric        MilestoneMetric // DPS | HPS
  value         Float
  achievedAt    DateTime      @default(now())
  supersededAt  DateTime?     // set when rank is beaten

  @@index([bossId, difficulty, metric])
  @@index([playerId])
  @@map("milestones")
}

enum MilestoneType {
  ALL_TIME_RANK
  WEEKLY_BEST
  PERSONAL_BEST
}

enum MilestoneMetric {
  DPS
  HPS
}

// ─────────────────────────────────────────────
//  WEEKLY SUMMARY  (materialised for fast reads)
// ─────────────────────────────────────────────

model WeeklySummary {
  id           String   @id @default(cuid())
  weekStart    DateTime
  weekEnd      DateTime
  realmId      String?
  guildId      String?
  totalKills   Int      @default(0)
  totalWipes   Int      @default(0)
  totalUploads Int      @default(0)
  topDps       Json     // { playerName, bossName, difficulty, dps }[]
  topHps       Json     // { playerName, bossName, difficulty, hps }[]
  bossKills    Json     // { bossName, kills, wipes, bestTimeMs }[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([weekStart, realmId, guildId])
  @@map("weekly_summaries")
}

// ─────────────────────────────────────────────
//  WOW ITEM CACHE  (static WotLK item metadata)
// ─────────────────────────────────────────────

model WowItem {
  itemId        String   @id                // WoW item ID as string
  name          String
  itemLevel     Int?
  quality       String?                     // "poor"|"common"|"uncommon"|"rare"|"epic"|"legendary"
  equipLoc      String?                     // INVTYPE_* string
  iconName      String?                     // zamimg icon slug, e.g. "inv_sword_01"

  // AzerothCore item_template fields (populated by import-item-template script)
  itemClass     Int?
  itemSubclass  Int?
  displayId     Int?
  requiredLevel Int?
  armor         Int?
  dmgMin        Float?
  dmgMax        Float?
  delay         Int?                        // weapon speed in ms
  bonding       Int?                        // 0=none, 1=BoP, 2=BoE, 3=BoU
  description   String?
  stats         Json?                       // { "Stamina": 74, "Intellect": 56, ... }
  socketColors  Json?                       // [1, 2, 0] socket color per slot, 0=none
  socketBonus   Int?
  importedAt    DateTime?                   // set when row was imported from item_template

  @@map("wow_items")
}
